# Skills Hub 生产环境配置
# 复制此文件为 .env.prod 并修改相应配置
# 重要：所有敏感信息请使用强密码并妥善保管

# ==================== 镜像配置 ====================
IMAGE_REGISTRY=swr.cn-north-4.myhuaweicloud.com
IMAGE_NAMESPACE=skillhub
IMAGE_NAME=skillhub
IMAGE_TAG=latest

# ==================== 服务配置 ====================
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
RUN_MODE=prod

# ==================== 数据库配置 ====================
# 重要：生产环境请使用强密码
DATABASE_URL=postgres://skillhub:CHANGE_ME@postgres:5432/skillhub
POSTGRES_USER=skillhub
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=skillhub
POSTGRES_PORT=5432

# ==================== Redis 配置 ====================
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# ==================== JWT 配置 ====================
# 重要：生产环境请使用 256 位以上的随机字符串
JWT_SECRET=CHANGE_ME_TO_A_SECURE_RANDOM_STRING
JWT_EXPIRATION=86400

# ==================== 存储配置 ====================
# MinIO 配置
STORAGE_TYPE=minio
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=skillhub
MINIO_USE_SSL=false

# ==================== CORS 配置 ====================
# 重要：生产环境请配置实际域名
CORS_ALLOWED_ORIGINS=https://your-domain.com
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# ==================== 日志配置 ====================
RUST_LOG=info

# ==================== 其他配置 ====================
# 初始管理员账号
# 重要：生产环境请修改默认密码
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME

# 文件上传限制 (MB)
MAX_UPLOAD_SIZE=100

# ==================== 安全配置 ====================
# 密码加密轮次
PASSWORD_HASH_ROUNDS=12

# 会话超时时间 (秒)
SESSION_TIMEOUT=3600