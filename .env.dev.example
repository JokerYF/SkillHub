# Skills Hub 开发环境配置
# 复制此文件为 .env.dev 并修改相应配置

# ==================== 镜像配置 ====================
IMAGE_REGISTRY=swr.cn-north-4.myhuaweicloud.com
IMAGE_NAMESPACE=skillhub
IMAGE_NAME=skillhub
IMAGE_TAG=dev-latest

# ==================== 服务配置 ====================
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
RUN_MODE=dev

# ==================== 数据库配置 ====================
DATABASE_URL=postgres://skillhub:skillhub123@postgres:5432/skillhub
POSTGRES_USER=skillhub
POSTGRES_PASSWORD=skillhub123
POSTGRES_DB=skillhub
POSTGRES_PORT=5432

# ==================== Redis 配置 ====================
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# ==================== JWT 配置 ====================
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRATION=86400

# ==================== 存储配置 ====================
# MinIO 配置 (如需使用)
# STORAGE_TYPE=minio
# MINIO_ENDPOINT=minio:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=skillhub

# 本地文件存储
STORAGE_TYPE=local
STORAGE_PATH=/app/data

# ==================== CORS 配置 ====================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# ==================== 日志配置 ====================
RUST_LOG=debug

# ==================== 其他配置 ====================
# 初始管理员账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# 文件上传限制 (MB)
MAX_UPLOAD_SIZE=100